NODE_ENV=development
PORT=4000
MONGODB_URI=
CLERK_SECRET_KEY=sk_test_xxx
# Optional unless you enable Stripe routes
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLAID_CLIENT_ID=plaid_client_id_xxx
PLAID_SECRET=plaid_secret_xxx
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=https://your-app.example.com/plaid/oauth
# Optional dev: omit for plaintext tokens. Production: base64-encoded 32-byte key, e.g. node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PLAID_ACCESS_TOKEN_KEY=
CORS_ORIGINS=http://localhost:8081

